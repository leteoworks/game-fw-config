{
  "schemaVersion": 1,
  "analytics": {
    "posthog": {
      "enabled": true,
      "batching": {
        "flushIntervalMs": 15000,
        "maxBatchSize": 50,
        "flushOnPageHide": true
      },
      "blockedEvents": [],
      "allowedEvents": [
        "run.started",
        "run.ended",
        "play.session.summary",
        "device.profile",
        "$exception",
        "error.handled",
        "error.occurred",
        "error.resource_failed",
        "error.network",
        "performance.degraded",
        "locale.detection.mismatch",
        "remote.config.applied",
        "remote.config.fetched",
        "remote.config.rejected",
        "paywall.shown",
        "paywall.dismissed",
        "freewall.shown",
        "freewall.continued",
        "paywall.purchase.started",
        "paywall.purchase.completed",
        "paywall.purchase.failed",
        "paywall.purchase.cancelled",
        "paywall.restore.started",
        "paywall.restore.completed",
        "paywall.restore.failed",
        "settings.changed",
        "death.detail",
        "level.started",
        "level.completed",
        "record.broken",
        "progress.milestone",
        "speed.increased",
        "food.eaten",
        "run.restarted",
        "powerup.collected",
        "powerup.expired",
        "extra.life.used",
        "auto.snake.session",
        "crash.recovery.detected",
        "crash.recovery.resumed",
        "tutorial.dismissed",
        "control.mode.chosen",
        "orientation.chosen",
        "profiling.hotspot",
        "app.booted",
        "screen.viewed",
        "screen.exited",
        "first.action.after.boot",
        "run.input.breakdown",
        "modal.opened",
        "modal.closed",
        "signal.health",
        "modsys.health.activate",
        "modsys.health.deactivate",
        "modsys.health.session-summary",
        "modsys.health.perf-degradation",
        "modsys.health.engine-fallback",
        "modsys.health.cb-throws",
        "modsys.security.permission-denied",
        "modsys.security.rate-limit-hit",
        "modsys.security.too-many-hooks",
        "modsys.security.callback-faulty-storm",
        "modsys.security.signature-invalid",
        "modsys.security.manifest-tampered",
        "modsys.security.wiki-source-traversal",
        "modsys.security.manifest-extras-rejected",
        "modsys.framework.discovered",
        "modsys.framework.upgrade",
        "modsys.framework.removed",
        "modsys.framework.permission_prompt_shown",
        "modsys.framework.permission_decision",
        "modsys.framework.activated",
        "modsys.framework.deactivated",
        "modsys.framework.session_summary",
        "modsys.framework.engagement_tick",
        "modsys.framework.first_use_ever",
        "modsys.framework.fault_summary",
        "modsys.framework.quota_hit",
        "modsys.framework.api_violation",
        "modsys.framework.perf.frame_impact",
        "modsys.framework.perf.cpu_budget",
        "modsys.framework.perf.memory_high_water",
        "modsys.framework.perf.hook_slow",
        "modsys.framework.perf.long_task_attributed",
        "modsys.framework.perf.budget_exceeded",
        "modsys.framework.perf.throttled",
        "modsys.framework.workshop_detected",
        "modsys.framework.workshop_auto_updated",
        "modsys.framework.workshop_unavailable",
        "modsys.framework.sideload_retail_activated",
        "modsys.framework.sideload_retail_expired",
        "modsys.framework.sideload_hot_reload",
        "modsys.framework.support_author_clicked",
        "modsys.framework.rate-limit-exceeded"
      ]
    }
  },
  "paywall": {
    "enabled": false,
    "triggers": [
      {
        "episodeIndex": 1,
        "beforeSceneIndex": 1
      }
    ],
    "freeEpisodeLimit": 2
  },
  "freewall": {
    "enabled": false,
    "triggers": [
      {
        "episodeIndex": 1,
        "beforeSceneIndex": 1
      }
    ],
    "frequency": {
      "mode": "cooldown",
      "cooldownDays": 7
    },
    "overrides": {
      "ios": {
        "enabled": true
      },
      "android": {
        "enabled": true
      },
      "electron-mac-appstore": {
        "enabled": true
      }
    }
  },
  "profiling": {
    "enabled": true,
    "cohortPercent": 100,
    "signals": {
      "fps": true,
      "longTasks": true,
      "memory": true,
      "systems": true,
      "entities": true,
      "events": true
    }
  }
}
