{
  "schemaVersion": 1,
  "analytics": {
    "posthog": {
      "enabled": true,
      "batching": {
        "flushIntervalMs": 2000,
        "maxBatchSize": 1,
        "flushOnPageHide": true
      },
      "blockedEvents": [],
      "allowedEvents": [
        "run.started",
        "run.ended",
        "play.session.summary",
        "device.profile",
        "$exception",
        "error.handled",
        "error.occurred",
        "error.resource_failed",
        "error.network",
        "performance.degraded",
        "locale.detection.mismatch",
        "remote.config.applied",
        "remote.config.fetched",
        "remote.config.rejected",
        "paywall.shown",
        "paywall.dismissed",
        "freewall.shown",
        "freewall.continued",
        "paywall.purchase.started",
        "paywall.purchase.completed",
        "paywall.purchase.failed",
        "paywall.purchase.cancelled",
        "paywall.restore.started",
        "paywall.restore.completed",
        "paywall.restore.failed",
        "settings.changed",
        "death.detail",
        "level.started",
        "level.completed",
        "record.broken",
        "progress.milestone",
        "speed.increased",
        "food.eaten",
        "run.restarted",
        "powerup.collected",
        "powerup.expired",
        "extra.life.used",
        "auto.snake.session",
        "crash.recovery.detected",
        "crash.recovery.resumed",
        "tutorial.dismissed",
        "control.mode.chosen",
        "orientation.chosen",
        "profiling.hotspot",
        "app.booted",
        "screen.viewed",
        "screen.exited",
        "first.action.after.boot",
        "run.input.breakdown",
        "modal.opened",
        "modal.closed"
      ]
    }
  },
  "paywall": {
    "enabled": false,
    "triggers": [
      {
        "episodeIndex": 1,
        "beforeSceneIndex": 1
      }
    ],
    "freeEpisodeLimit": 2
  },
  "freewall": {
    "enabled": false,
    "triggers": [
      {
        "episodeIndex": 1,
        "beforeSceneIndex": 1
      }
    ],
    "frequency": {
      "mode": "cooldown",
      "cooldownDays": 7
    },
    "overrides": {
      "ios": {
        "enabled": true
      },
      "android": {
        "enabled": true
      },
      "electron-mac-appstore": {
        "enabled": true
      }
    }
  },
  "profiling": {
    "enabled": true,
    "cohortPercent": 100,
    "signals": {
      "fps": true,
      "longTasks": true,
      "memory": true,
      "systems": true,
      "entities": true,
      "events": true
    }
  }
}
